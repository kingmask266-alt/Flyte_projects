// Docs: https://dbml.dbdiagram.io/docs

Table Users {
  id int [pk, increment]
  username varchar(50) [unique, not null]
  email varchar(100) [unique, not null]
  password varchar(255) [not null]
  role varchar(20)
  created_at datetime [default: `now()`]
}

Table Airport {
  id int [pk, increment]
  name varchar(100) [not null]
  code varchar(10) [unique, not null]
  city varchar(50)
  country varchar(50)
}

Table Airline {
  id int [pk, increment]
  name varchar(100) [unique, not null]
  code varchar(10) [unique, not null]
  country varchar(50)
}

Table Flights {
  id int [pk, increment]
  flight_number varchar(20) [unique, not null]
  airline_id int [not null]
  departure_airport_id int [not null]
  arrival_airport_id int [not null]
  departure_time datetime [not null]
  arrival_time datetime [not null]
  capacity int
}

Table Passenger {
  id int [pk, increment]
  first_name varchar(50) [not null]
  last_name varchar(50) [not null]
  email varchar(100) [unique, not null]
  phone varchar(20)
  passport_number varchar(20) [unique]
}

Table Booking {
  id int [pk, increment]
  booking_reference varchar(20) [unique, not null]
  passenger_id int [not null]
  flight_id int [not null]
  seat_number varchar(10)
  status varchar(20)
  booked_at datetime [default: `now()`]
}

Table Ticket {
  id int [pk, increment]
  ticket_number varchar(20) [unique, not null]
  booking_id int [not null]
  seat_number varchar(10)
  issued_at datetime [default: `now()`]
}

Table Payment {
  id int [pk, increment]
  booking_id int [not null]
  amount decimal(10,2) [not null]
  method varchar(20)
  status varchar(20)
  paid_at datetime
}



Ref: Flights.airline_id > Airline.id
Ref: Flights.departure_airport_id > Airport.id
Ref: Flights.arrival_airport_id > Airport.id

Ref: Booking.passenger_id > Passenger.id
Ref: Booking.flight_id > Flights.id

Ref: Ticket.booking_id > Booking.id
Ref: Payment.booking_id > Booking.id
